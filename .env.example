# =============================================================================
# DCL Engine — Environment Variables
# Copy to .env and fill in values before running.
# =============================================================================

# --- Core ---
DCL_ENV=dev                        # dev | production
RUN_MODE=dev                       # dev | prod (Render uses this)
BACKEND_PORT=8000                  # API listen port (default 8000)

# --- Database ---
DATABASE_URL=                      # PostgreSQL connection string
SUPABASE_DB_URL=                   # Alias — same as DATABASE_URL (Render sets both)

# --- DCL Identity ---
DCL_URL=                           # DCL's own public URL (self-reference)
DCL_API_URL=                       # DCL API URL (used by other services)
DCL_INGEST_KEY=                    # Auth key for the /api/dcl/ingest endpoint
DCL_DATASET_ID=nlq_test            # Dataset identifier
SOURCE_NAME=                       # Data source name
SESSION_SECRET=                    # Session signing key

# --- AI / LLM ---
OPENAI_API_KEY=                    # OpenAI — used for Prod-mode mapping validation & embeddings
ANTHROPIC_API_KEY=                 # Anthropic — used by autonomous_worker
GEMINI_API_KEY=                    # Google Gemini — used for classification
LLM_MODEL_NAME=gpt-4o             # Model for LLM mapping validation
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector DB (Pinecone) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=dcl-mappings
PINECONE_DIMENSION=1536
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- External APIs ---
FARM_API_URL=https://farmv2.onrender.com    # AOS-Farm data source
AAM_API_URL=                           # AAM service URL
AAM_URL=                               # AAM URL alias (Render sets both)
AAM_API_TIMEOUT=30
AAM_EDGE_CACHE_TTL=300
AAM_EDGE_CONFIDENCE_MIN=0.5

# --- Redis (optional, for narration streaming) ---
REDIS_URL=

# --- MCP Server ---
MCP_API_KEY=

# --- CORS ---
CORS_ORIGINS=*                     # Comma-separated origins, or * for dev

# --- Autonomous Worker (optional) ---
SLACK_WEBHOOK_URL=
REPO_PATH=.
NLQ_ENDPOINT=
CHECK_INTERVAL=300

# --- Confidence Thresholds (optional, sensible defaults built in) ---
# DCL_CONFIDENCE_POSITIVE_PATTERN=
# DCL_CONFIDENCE_EXACT_FIELD=
# DCL_CONFIDENCE_PARTIAL_FIELD=
# DCL_CONFIDENCE_SYNONYM=
# DCL_CONFIDENCE_CONCEPT_IN_NAME=
# DCL_CONFIDENCE_CONTEXT_BOOST=
# DCL_CONFIDENCE_CONTEXT_CAP=
# DCL_CONFIDENCE_SEMANTIC_AMOUNT=
# DCL_CONFIDENCE_SEMANTIC_ID=
# DCL_CONFIDENCE_CONCEPT_MATCH=
# DCL_CONFIDENCE_EXAMPLE_EXACT=
# DCL_CONFIDENCE_EXAMPLE_PARTIAL=
# DCL_CONFIDENCE_DEFAULT=
# DCL_RAG_CONFIDENCE_THRESHOLD=
# DCL_LLM_VALIDATION_THRESHOLD=
# DCL_TRUST_SCORE_FALLBACK=

# --- Cache TTLs (seconds, optional) ---
# DCL_ONTOLOGY_CACHE_TTL=
# DCL_MAPPINGS_CACHE_TTL=
# DCL_SCHEMA_CACHE_TTL=

# --- Connection Pool (optional) ---
# DCL_POOL_RETRY_COOLDOWN=
# DCL_POOL_MIN_CONN=
# DCL_POOL_MAX_CONN=
# DCL_DB_CONNECT_TIMEOUT=

# --- Circuit Breaker / Timeouts (optional) ---
# DCL_CB_COOLDOWN=
# DCL_FARM_REGISTRY_TIMEOUT=
# DCL_FARM_BROWSER_TIMEOUT=

# --- ME Boundary Guard ---
# ME entity_ids that must not be ingested into DCL (SE-only).
# ME data routes to Convergence (port 8010). Comma-separated.
# DCL_BLOCKED_ENTITY_IDS=<entity_a>,<entity_b>,<combined_tag>

# --- Testing ---
ENABLE_CHAOS=false                 # Enable chaos testing (default false)
